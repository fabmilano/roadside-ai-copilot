# Gemini API key (required)
LLM_API_KEY=your-gemini-api-key-here

# LLM fallback chain - tried in order on any failure (optional, defaults shown)
LLM_MODEL_CHAIN=gemini/gemini-2.5-flash-lite,gemini/gemini-2.5-flash,gemini/gemini-3.1-flash-lite-preview,gemini/gemini-3-flash-preview

# Embedding model - no fallback, must be available on your API key (optional, default shown)
EMBEDDING_MODEL_NAME=gemini/gemini-embedding-001
